# =============================================================================
# twingate-device-trust-bridge — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Secrets go here. Non-secret settings belong in config.yaml.
# =============================================================================

# -----------------------------------------------------------------------------
# Twingate
# -----------------------------------------------------------------------------
# Your Twingate account subdomain (e.g. "mycompany" for mycompany.twingate.com)
TWINGATE_TENANT=mycompany

# Admin API key — generate at Settings → API → Generate Token
TWINGATE_API_KEY=

# -----------------------------------------------------------------------------
# Sync behaviour (overrides config.yaml defaults)
# -----------------------------------------------------------------------------
# How often to run a full sync, in seconds. Default: 300 (5 minutes)
SYNC_INTERVAL_SECONDS=300

# Set to "true" to log trust decisions without calling the Twingate mutation.
DRY_RUN=false

# -----------------------------------------------------------------------------
# NinjaOne (NinjaRMM)
# Auth: OAuth2 Client Credentials
# -----------------------------------------------------------------------------
NINJAONE_CLIENT_ID=
NINJAONE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Sophos Central
# Auth: OAuth2 Client Credentials
# -----------------------------------------------------------------------------
SOPHOS_CLIENT_ID=
SOPHOS_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# ManageEngine Endpoint Central
# Auth (on-prem): API token
# Auth (cloud):   OAuth2 via Zoho
# -----------------------------------------------------------------------------
MANAGEENGINE_API_TOKEN=

MANAGEENGINE_OAUTH_CLIENT_ID=
MANAGEENGINE_OAUTH_CLIENT_SECRET=
MANAGEENGINE_OAUTH_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Automox
# Auth: API key as Bearer token
# -----------------------------------------------------------------------------
AUTOMOX_API_KEY=

# -----------------------------------------------------------------------------
# JumpCloud
# Auth: API key via x-api-key header
# -----------------------------------------------------------------------------
JUMPCLOUD_API_KEY=

# -----------------------------------------------------------------------------
# FleetDM
# Auth: API token as Bearer token
# -----------------------------------------------------------------------------
FLEETDM_API_TOKEN=

# -----------------------------------------------------------------------------
# Mosyle (Apple MDM)
# Auth: access token + email + password (sent in request body)
# -----------------------------------------------------------------------------
MOSYLE_ACCESS_TOKEN=
MOSYLE_EMAIL=
MOSYLE_PASSWORD=

# -----------------------------------------------------------------------------
# Datto RMM
# Auth: OAuth2 (api_key + api_secret_key → Bearer token)
# -----------------------------------------------------------------------------
DATTO_API_KEY=
DATTO_API_SECRET=
