# =============================================================================
# twingate-device-trust-bridge — Configuration File
# =============================================================================
# Copy this file to config.yaml and adjust for your environment.
#
# ${VAR} placeholders are resolved from environment variables at startup.
# This file should NOT contain raw secrets — use ${ENV_VAR} references or
# set values directly in your .env file.
# =============================================================================

# -----------------------------------------------------------------------------
# Twingate connection
# -----------------------------------------------------------------------------
twingate:
  tenant: ${TWINGATE_TENANT}       # e.g. "mycompany" → mycompany.twingate.com
  api_key: ${TWINGATE_API_KEY}

# -----------------------------------------------------------------------------
# Sync behaviour
# -----------------------------------------------------------------------------
sync:
  interval_seconds: 300            # How often to run a full sync (seconds)
  dry_run: false                   # true = log decisions only, no mutations
  batch_size: 50                   # Twingate pagination batch size

# -----------------------------------------------------------------------------
# Device matching
# -----------------------------------------------------------------------------
matching:
  primary_key: serial_number       # Only "serial_number" supported in v1
  normalize: true                  # strip().upper() before comparison

# -----------------------------------------------------------------------------
# Trust evaluation
# -----------------------------------------------------------------------------
trust:
  mode: any                        # "any" = trust if compliant in ANY provider
                                   # "all" = trust only if compliant in ALL providers
  require_online: true             # Device must be online in the provider
  require_compliant: true          # Device must pass provider compliance checks
  max_days_since_checkin: 7        # Reject devices not seen in N days

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
logging:
  level: INFO                      # DEBUG | INFO | WARNING | ERROR
  format: json                     # "json" (stdout) — only option in v1
  timezone: UTC                    # IANA timezone name — affects log timestamps and email timestamps

# -----------------------------------------------------------------------------
# Providers
#
# List one entry per provider. Set enabled: true to activate.
# All secrets must use ${ENV_VAR} references.
# -----------------------------------------------------------------------------
providers:

  # ---------------------------------------------------------------------------
  # NinjaOne (NinjaRMM)
  # Auth: OAuth2 Client Credentials
  # Regions: us (app), eu, ca, au, oc
  # ---------------------------------------------------------------------------
  - type: ninjaone
    enabled: false
    region: us                     # us | eu | ca | au | oc
    client_id: ${NINJAONE_CLIENT_ID}
    client_secret: ${NINJAONE_CLIENT_SECRET}

  # ---------------------------------------------------------------------------
  # Sophos Central
  # Auth: OAuth2 Client Credentials + /whoami/v1 tenant discovery
  # ---------------------------------------------------------------------------
  - type: sophos
    enabled: false
    client_id: ${SOPHOS_CLIENT_ID}
    client_secret: ${SOPHOS_CLIENT_SECRET}

  # ---------------------------------------------------------------------------
  # ManageEngine Endpoint Central — on-prem variant
  # Auth: API token
  # ---------------------------------------------------------------------------
  - type: manageengine
    enabled: false
    variant: onprem                # "onprem" or "cloud"
    base_url: https://uems.company.com:8020
    api_token: ${MANAGEENGINE_API_TOKEN}

  # ---------------------------------------------------------------------------
  # ManageEngine Endpoint Central — cloud variant (uncomment to use)
  # Auth: OAuth2 via Zoho Self Client
  # See docs/providers/manageengine.md for setup instructions and region URLs
  # ---------------------------------------------------------------------------
  # - type: manageengine
  #   enabled: false
  #   variant: cloud
  #   base_url: ${MANAGEENGINE_BASE_URL}          # e.g. https://endpointcentral.manageengine.com
  #   oauth_client_id: ${MANAGEENGINE_OAUTH_CLIENT_ID}
  #   oauth_client_secret: ${MANAGEENGINE_OAUTH_CLIENT_SECRET}
  #   oauth_refresh_token: ${MANAGEENGINE_OAUTH_REFRESH_TOKEN}
  #   oauth_token_url: ${MANAGEENGINE_OAUTH_TOKEN_URL}  # omit for US accounts
  #
  #   # Compliance checks (all optional — omitting uses the defaults shown)
  #   compliance:
  #     require_installed: true   # agent must be installed (installation_status == 22)
  #     require_live: false       # set true to also require machine is online (computer_live_status == 1)

  # ---------------------------------------------------------------------------
  # Automox
  # Auth: API key Bearer token
  # ---------------------------------------------------------------------------
  - type: automox
    enabled: false
    org_id: "12345"                # Your Automox organisation ID
    api_key: ${AUTOMOX_API_KEY}

  # ---------------------------------------------------------------------------
  # JumpCloud
  # Auth: x-api-key header
  # ---------------------------------------------------------------------------
  - type: jumpcloud
    enabled: false
    api_key: ${JUMPCLOUD_API_KEY}

  # ---------------------------------------------------------------------------
  # FleetDM
  # Auth: Bearer token
  # ---------------------------------------------------------------------------
  - type: fleetdm
    enabled: false
    url: https://fleet.company.com # Your Fleet server URL (no trailing slash)
    api_token: ${FLEETDM_API_TOKEN}

  # ---------------------------------------------------------------------------
  # Mosyle (Apple MDM — macOS, iOS, iPadOS only)
  # Auth: access token + email + password in request body
  # ---------------------------------------------------------------------------
  - type: mosyle
    enabled: false
    is_business: false             # true = Mosyle Business; false = Mosyle Manager
    access_token: ${MOSYLE_ACCESS_TOKEN}
    email: ${MOSYLE_EMAIL}
    password: ${MOSYLE_PASSWORD}

  # ---------------------------------------------------------------------------
  # Datto RMM
  # Auth: OAuth2 (api_key + api_secret → Bearer token, expires 100h)
  # Regions: pinotage | merlot | concord | vidal | syrah | zinfandel
  # ---------------------------------------------------------------------------
  - type: datto
    enabled: false
    api_url: https://pinotage-api.centrastage.net  # Replace with your region
    api_key: ${DATTO_API_KEY}
    api_secret: ${DATTO_API_SECRET}

  # ---------------------------------------------------------------------------
  # Rippling (HR/IT platform — requires IT Management add-on)
  # Auth: OAuth2 Client Credentials
  # ---------------------------------------------------------------------------
  - type: rippling
    enabled: false
    client_id: ${RIPPLING_CLIENT_ID}
    client_secret: ${RIPPLING_CLIENT_SECRET}

# ---------------------------------------------------------------------------
# Notifications (optional)
# ---------------------------------------------------------------------------
# Omit this entire block to disable all notifications.
# Both channels are independently optional.

# notifications:

  # SMTP email — alerts and daily digest
#   smtp:
#     host: smtp.example.com
#     port: 587
#     username: ${SMTP_USERNAME}
#     password: ${SMTP_PASSWORD}
#     from: twingate-bridge@example.com
#     to:
#       - it-admin@example.com
#       - security@example.com
#     tls_mode: starttls           # "starttls" (port 587) or "tls" (port 465)
#
#     # Optional: path to a directory with custom email templates.
#     # Copy files from src/notifications/templates/ and edit freely.
#     # templates_dir: /opt/twingate-templates
#
#     # Which events trigger immediate alert emails.
#     # Future events (e.g. device_untrusted) can be added here without code changes.
#     alerts:
#       enabled: true
#       events:
#         - provider_error
#         - mutation_error
#         - startup_failure
#
#     # Daily digest summary (disabled by default).
#     digest:
#       enabled: false
#       schedule: "08:00"   # HH:MM
#       timezone: UTC       # IANA timezone name

  # HTTP webhooks — JSON POST with optional HMAC-SHA256 signing
#   webhook:
#     url: ${WEBHOOK_URL}
#     secret: ${WEBHOOK_SECRET}       # optional — enables X-Hub-Signature-256 header
#     timeout_seconds: 10
#     # Which events to fire. Future events can be added without code changes.
#     events:
#       - device_trusted
#       - provider_error
#       - sync_complete
